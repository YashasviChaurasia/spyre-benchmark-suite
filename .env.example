# Spyre Benchmark Suite — Environment Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# This file is sourced by run.sh automatically.
# NEVER commit .env to git (it's in .gitignore).

# === Benchmark Cluster ===
# OpenShift API server for the Spyre benchmark cluster
BENCHMARK_SERVER=https://api.torch-cicd.spyre.res.ibm.com:6443

# === ClickHouse (Dashboard Push) ===
# Public HTTPS route to ClickHouse on the dashboard cluster
CLICKHOUSE_URL=https://clickhouse-ingest-spyre-cdev.apps.fmaas-devstage-backend.fmaas.res.ibm.com
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
